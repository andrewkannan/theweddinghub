generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==============================================================================
// NEXTAUTH MODELS (SaaS Authentication & Accounts)
// ==============================================================================
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("couple") // "couple", "planner", "vendor", "admin"
  tier          String    @default("free") // "free", "premium_couple", "planner_pro", "enterprise"
  
  // AI Settings
  openaiApiKey  String?
  geminiApiKey  String?

  accounts      Account[]
  sessions      Session[]
  weddings      Wedding[] @relation("OwnedWeddings")
  collaborations WeddingCollaborator[]
  
  // Vendor specific data
  vendorProfile VendorProfile?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==============================================================================
// CORE WEDDING PLATFORM
// ==============================================================================

model Wedding {
  id          String    @id @default(cuid())
  name        String
  date        DateTime?
  location    String?
  totalBudget Float     @default(0)
  theme       String?
  status      String    @default("planning") // "planning", "wedding_day", "completed"
  
  userId      String
  owner       User      @relation("OwnedWeddings", fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  collaborators WeddingCollaborator[]
  budgetItems   BudgetItem[]
  vendors       Vendor[]
  tasks         Task[]
  guests        Guest[]
  schedules     Schedule[]
  issues        Issue[]
  moodboards    Moodboard[]
  notes         Note[]
  tables        Table[]
  notifications Notification[]
}

model WeddingCollaborator {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weddingId String
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  role      String   @default("editor") // "viewer", "editor", "co_owner"
  
  createdAt DateTime @default(now())
  
  @@unique([userId, weddingId])
}

// ==============================================================================
// FINANCIAL & BUDGETING (Stripe-like Dashboard Data)
// ==============================================================================

model BudgetItem {
  id            String   @id @default(cuid())
  category      String   // "venue", "catering", "photography", etc.
  itemName      String
  estimatedCost Float    @default(0)
  actualCost    Float    @default(0)
  dueDate       DateTime?
  status        String   @default("pending") // "pending", "partially_paid", "paid"
  
  weddingId     String
  wedding       Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  
  payments      Payment[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Payment {
  id            String     @id @default(cuid())
  amount        Float
  date          DateTime
  method        String?    // "bank_transfer", "card", "cash"
  receiptUrl    String?
  notes         String?
  
  budgetItemId  String?
  budgetItem    BudgetItem? @relation(fields: [budgetItemId], references: [id], onDelete: SetNull)
  
  vendorId      String?
  vendor        Vendor?    @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

// ==============================================================================
// VENDOR MANAGEMENT
// ==============================================================================

model VendorProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName String
  category    String
  description String?
  portfolioUrl String?
  rating      Float    @default(0)
  isVerified  Boolean  @default(false)
}

model Vendor {
  id          String   @id @default(cuid())
  name        String
  category    String
  contactInfo String?
  email       String?
  phone       String?
  quotedPrice Float    @default(0)
  finalPrice  Float    @default(0)
  status      String   @default("shortlisted") // "shortlisted", "hired", "rejected", "completed"
  
  contractUrl String?
  
  weddingId   String
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  
  payments    Payment[]
  tasks       Task[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==============================================================================
// TASK & TIMELINE (Trello/Linear style)
// ==============================================================================

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  owner       String?
  deadline    DateTime?
  priority    String   @default("medium") // "low", "medium", "high", "urgent"
  status      String   @default("todo") // "todo", "in_progress", "done"
  stage       String   @default("general") // "12_months", "6_months", "wedding_day", etc.
  
  weddingId   String
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  
  vendorId    String?
  vendor      Vendor?  @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==============================================================================
// GUEST & SEATING MANAGEMENT
// ==============================================================================

model Guest {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String?
  email         String?
  phone         String?
  groupName     String?  // Family or friend group
  side          String?  // "bride", "groom", "mutual"
  rsvpStatus    String   @default("pending") // "pending", "attending", "declined"
  paxCount      Int      @default(1)
  dietaryNotes  String?
  isVIP         Boolean  @default(false)
  
  tableId       String?
  table         Table?   @relation(fields: [tableId], references: [id], onDelete: SetNull)
  
  weddingId     String
  wedding       Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Table {
  id          String   @id @default(cuid())
  name        String   // "Table 1", "VIP Table"
  capacity    Int      @default(10)
  shape       String   @default("round") // "round", "rectangular"
  
  weddingId   String
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  
  guests      Guest[]
}

// ==============================================================================
// SCHEDULING (Apple Calendar style)
// ==============================================================================

model Schedule {
  id          String   @id @default(cuid())
  title       String
  startTime   DateTime
  endTime     DateTime
  location    String?
  description String?  @db.Text
  isWeddingDay Boolean @default(false)
  
  weddingId   String
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==============================================================================
// BRAINSTORMING & MOODBOARDS (Pinterest/Notion style)
// ==============================================================================

model Moodboard {
  id          String   @id @default(cuid())
  title       String
  description String?
  
  weddingId   String
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  
  images      Image[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Image {
  id          String   @id @default(cuid())
  url         String
  caption     String?
  
  moodboardId String
  moodboard   Moodboard @relation(fields: [moodboardId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
}

model Note {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text // Can store Markdown or rich text
  
  weddingId   String
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==============================================================================
// COMMUNICATIONS & ALERTS
// ==============================================================================

model Notification {
  id          String   @id @default(cuid())
  type        String   // "task_due", "payment_due", "rsvp_received", "system"
  message     String
  isRead      Boolean  @default(false)
  
  weddingId   String
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
}

model Issue {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  priority    String   @default("medium")
  status      String   @default("open")
  deadline    DateTime?
  
  weddingId   String
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
